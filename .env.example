# ── Sentrix Configuration ─────────────────────────────────────
# Network to connect to: "mainnet" or "testnet" (Default: mainnet)
SENTRIX_NETWORK=mainnet

# Polling interval in seconds (min: 5, max: 300, Default: 30)
SENTRIX_POLL_INTERVAL=30

# Demo mode (use mock data instead of live chain). Set to true to test without keys.
SENTRIX_DEMO=false

# Comma-separated list of Injective wallet addresses to watch (e.g., inj1...,inj1...)
# Set to "demo" when running in demo mode.
# Get from: Your Keplr, Leap, or Injective wallet address
SENTRIX_ADDRESSES=inj1your_address_here

# ── LLM Providers ────────────────────────────────────────────
# OpenAI API Key for GPT-4o-mini risk explanations (optional, falls back to template alerts if missing)
# Get from: https://platform.openai.com/api-keys (Create a new secret key)
OPENAI_API_KEY=sk-...

# Google Gemini API Key for Gemini Flash risk explanations (optional)
# Get from: https://aistudio.google.com/app/apikey (Get API key)
GEMINI_API_KEY=AIza...

# ── Notifications ────────────────────────────────────────────
# Telegram Bot Token for sending alert notifications
# Get from: Telegram BotFather (https://t.me/BotFather) by using the /newbot command
SENTRIX_TELEGRAM_TOKEN=your_bot_token

# Telegram Chat ID to receive the bot messages
# Get from: Open Telegram, search for @userinfobot or @raw_data_bot, and copy your ID
SENTRIX_TELEGRAM_CHAT_ID=your_chat_id

# Discord Webhook URL for posting alerts to a channel
# Get from: Discord Channel Settings -> Integrations -> Webhooks -> Create Webhook -> Copy Webhook URL
SENTRIX_DISCORD_WEBHOOK=https://discord.com/api/webhooks/your_webhook_url
