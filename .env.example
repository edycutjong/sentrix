# ── Sentrix ──────────────────────────────────────────────────
# Get from: your wallet
SENTRIX_ADDRESSES=inj1your_address_here

# ── LLM Providers ────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# ── Notifications ────────────────────────────────────────────
# Get from: https://t.me/BotFather
SENTRIX_TELEGRAM_TOKEN=your_bot_token
# Get from: Telegram
SENTRIX_TELEGRAM_CHAT_ID=your_chat_id
# Get from: Discord Channel Settings -> Integrations -> Webhooks
SENTRIX_DISCORD_WEBHOOK=your_discord_webhook_url
